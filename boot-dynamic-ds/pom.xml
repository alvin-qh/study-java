<project
  xmlns="http://maven.apache.org/POM/4.0.0"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/maven-v4_0_0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <artifactId>study-java-boot-dynamic-datasource</artifactId>
  <version>1.0-SNAPSHOT</version>
  <packaging>jar</packaging>
  <name>${project.artifactId}</name>

  <!-- 从根项目 pom.xml 继承 -->
  <parent>
    <groupId>alvin.study</groupId>
    <artifactId>study-java-spring-boot3</artifactId>
    <version>1.0-SNAPSHOT</version>
    <relativePath>../pom-spring-boot3.xml</relativePath>
  </parent>

  <properties>
    <jdbc.url>jdbc:h2:${project.basedir}/.data/common;MODE=MYSQL</jdbc.url>
    <jdbc.user>dev</jdbc.user>
    <jdbc.password>password</jdbc.password>
  </properties>

  <!-- 配置依赖 -->
  <dependencies>
    <!-- Spring Boot Web 依赖 -->
    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-web</artifactId>
    </dependency>

    <!-- Spring Boot JDBC 依赖 -->
    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-jdbc</artifactId>
    </dependency>

    <!-- Spring Boot Bean 验证依赖 -->
    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-validation</artifactId>
    </dependency>

    <!-- Spring Boot AOP 依赖 -->
    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-aop</artifactId>
    </dependency>

    <!-- H2 DB 驱动依赖 -->
    <dependency>
      <groupId>com.h2database</groupId>
      <artifactId>h2</artifactId>
    </dependency>

    <!-- 数据库 Migration 依赖 -->
    <dependency>
      <groupId>org.flywaydb</groupId>
      <artifactId>flyway-core</artifactId>
      <scope>runtime</scope>
    </dependency>

    <!-- Spring Boot Webflux Starter, 这里仅用作测试 -->
    <dependency>
      <groupId>org.springframework.boot</groupId>
      <artifactId>spring-boot-starter-webflux</artifactId>
      <scope>test</scope>
    </dependency>
  </dependencies>

  <!-- 配置构建 -->
  <build>
    <!-- 配置构建插件 -->
    <plugins>
      <!-- Flyway 插件 -->
      <plugin>
        <groupId>org.flywaydb</groupId>
        <artifactId>flyway-maven-plugin</artifactId>
        <configuration>
          <!-- 数据库连接 -->
          <url>${jdbc.url}</url>
          <!-- 用户名 -->
          <user>${jdbc.user}</user>
          <!-- 密码 -->
          <password>${jdbc.password}</password>
          <!-- 脚本文件位置 -->
          <locations>
            <location>classpath:/migration/common</location>
          </locations>
          <!-- 版本存储表名称 -->
          <table>schema_version</table>
        </configuration>
      </plugin>
    </plugins>
  </build>
</project>
