<project xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xmlns="http://maven.apache.org/POM/4.0.0"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/maven-v4_0_0.xsd">
  <modelVersion>4.0.0</modelVersion>
  <artifactId>study-java-testing-parent</artifactId>
  <name>${project.artifactId}</name>
  <version>1.0-SNAPSHOT</version>
  <packaging>pom</packaging>

  <parent>
    <groupId>alvin.study</groupId>
    <artifactId>study-java-parent</artifactId>
    <version>1.0-SNAPSHOT</version>
    <relativePath>../pom.xml</relativePath>
  </parent>

  <modules>
    <module>testcase</module>
    <module>junit</module>
    <module>hamcrest</module>
    <module>assertj</module>
    <module>faker</module>
    <module>mock</module>
    <module>awaitility</module>
    <module>pioneer</module>
    <module>testng</module>
  </modules>

  <build>
    <plugins>
      <plugin>
        <!-- 覆盖 ../pom.xml 测试插件配置 -->
        <groupId>org.apache.maven.plugins</groupId>
        <artifactId>maven-surefire-plugin</artifactId>
        <configuration>
          <argLine>--enable-preview</argLine>
          <argLine>
            --add-opens="java.base/java.util=ALL-UNNAMED"
            --add-opens="java.base/java.lang=ALL-UNNAMED"
          </argLine>
        </configuration>
      </plugin>
    </plugins>
  </build>
</project>
